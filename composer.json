{
    "name": "worksome/exchange",
    "description": "Check Exchange Rates for any currency in Laravel.",
    "keywords": [
        "worksome",
        "laravel",
        "exchange"
    ],
    "homepage": "https://github.com/worksome/exchange",
    "license": "MIT",
    "authors": [
        {
            "name": "Luke Downing",
            "email": "lukeraymonddowning@gmail.com",
            "role": "Developer"
        },
        {
            "name": "Owen Voke",
            "email": "owen@worksome.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4",
        "illuminate/contracts": "^12.0|^13.0",
        "nunomaduro/termwind": "^2.4",
        "spatie/laravel-package-tools": "^1.93"
    },
    "require-dev": {
        "guzzlehttp/guzzle": "^7.11",
        "larastan/larastan": "^3.10",
        "nunomaduro/collision": "^8.9",
        "orchestra/testbench": "^10.11|^11.1",
        "pestphp/pest": "^4.7",
        "pestphp/pest-plugin-laravel": "^4.1",
        "worksome/coding-style": "^3.4"
    },
    "autoload": {
        "psr-4": {
            "Worksome\\Exchange\\": "src",
            "Worksome\\Exchange\\Database\\Factories\\": "database/factories"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Worksome\\Exchange\\Tests\\": "tests"
        }
    },
    "scripts": {
        "lint": "vendor/bin/ecs --fix",
        "test:unit": "vendor/bin/pest",
        "test:coverage": "vendor/bin/pest --coverage",
        "test:types": "vendor/bin/phpstan analyse",
        "test:style": "vendor/bin/ecs",
        "test": [
            "@test:style",
            "@test:types",
            "@test:unit"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "worksome/coding-style": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Worksome\\Exchange\\ExchangeServiceProvider"
            ],
            "aliases": {
                "Exchange": "Worksome\\Exchange\\Facades\\Exchange"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
